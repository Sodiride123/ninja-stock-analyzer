# ============================================================
# Earnings Research AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Claude API Key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# RapidAPI Key for real-time stock price data (optional)
# Get yours at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-finance-data
# If not set, price analysis will be skipped
RAPIDAPI_KEY=your_rapidapi_key_here

# SEC EDGAR User Agent (recommended to customize)
# SEC requires a valid user-agent with contact info
SEC_USER_AGENT=EarningsResearchApp your-email@example.com

# Server Configuration (optional)
SERVER_HOST=0.0.0.0
SERVER_PORT=8090